{
  "targets": [
    "pypi",
    "npm"
  ],
  "private": false,
  "push_timeout": 120,
  "pipelines": {
    "pypi": {
      "type": "pypi",
      "local": false
    },
    "npm": {
      "type": "npm",
      "local": false
    }
  },
  "batch_limits": {
    "exclusions": [
      {
        "reason": "non-user-facing batch",
        "entries": [
          {
            "version": "unreleased",
            "line": 1
          }
        ]
      }
    ]
  }
}
