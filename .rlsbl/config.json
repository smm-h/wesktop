{
  "targets": [
    "pypi",
    "npm"
  ],
  "private": false,
  "push_timeout": 120,
  "pipelines": {
    "pypi": {
      "type": "pypi",
      "local": false
    },
    "npm": {
      "type": "npm",
      "local": false
    }
  },
  "batch_limits": {
    "exclusions": []
  },
  "coverage_unit": "commit"
}
