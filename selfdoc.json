{
  "version": "0.6.0",
  "version_source": "pyproject.toml",
  "source": [
    {"path": "src/wesktop/", "language": "python"}
  ],
  "docs": "docs/",
  "output": "docs/_build/",
  "base_url": "https://wesktop.smmh.dev",
  "versions": [
    {
      "version": "0.6.0",
      "indexed": true
    }
  ],
  "locales": [
    {
      "code": "en",
      "label": "English",
      "default": true
    }
  ],
  "gen": {
    "exclude": [
      "src.wesktop"
    ]
  },
  "deploy": {
    "provider": "cloudflare-pages",
    "project": "wesktop"
  }
}
